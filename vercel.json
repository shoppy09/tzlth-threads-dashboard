{
  "version": 2,
  "github": { "enabled": false },
  "functions": {
    "api/publish-single.js": { "maxDuration": 60 },
    "api/nl-convert.js": { "maxDuration": 30 },
    "api/ai-split-thread.js": { "maxDuration": 30 }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/style.css", "dest": "/style.css" },
    { "src": "/app.js", "dest": "/app.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}

{
  "version": 2,
  "github": { "enabled": false },
  "functions": {
    "api/publish-single.js": { "maxDuration": 60 },
    "api/nl-convert.js": { "maxDuration": 30 },
    "api/ai-split-thread.js": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/:file(.*\\.(css|js|json|png|jpg|ico|svg|woff|woff2|ttf))", "destination": "/:file" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
